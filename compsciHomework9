#10-5
#write a while loop that prompts users for their name and adds it to guest.txt
guests = ""
path = Path("guest.txt")
print ("Input 'q' when you are done adding names")
while True:
    name = input("What is your name: \n")
    if name.lower() != "q":
        guests += (f"{name.title()}\n")
    else:
        break
path.write_text(guests)
print("\n")

#10-6
#make a program that prints two numbers together accounting for Value Errors
try:
    firstNum = int(input("Give me a number: "))
    secondNum = int(input("Give me a second number: "))
    print (f"This is the sum of those two numbers: {firstNum + secondNum}")
except ValueError:
    print("That is not a number")
print("\n")

#10-7
#do 10-6 again but as a while loop
firstNum = 0
secondNum = 0
print("Enter 'q' at any time to quit the loop")
while True:
    try:
        firstNum = input("Give me a number: ")
        if firstNum == "q":
            break
        firstNum = int(firstNum)
        secondNum = input("Give me a second number: ")
        if secondNum == "q":
            break
        secondNum = int(secondNum)
        print (f"This is the sum of those two numbers: {firstNum + secondNum}\n")
    except ValueError:
        print("That is not a number\n")

